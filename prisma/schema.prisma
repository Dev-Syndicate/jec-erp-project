// JEC ERP — Prisma schema
//
// The core data model, designed backbone-first around the college's four daily
// jobs (see docs/schema-design.html):
//   1. Attendance   — period-wise; period 1 sets the day's MasterAttendance
//   2. Student records
//   3. Faculty records
//   4. Internal marks — per semester (Odd / Even)
//   + Configurable RBAC with a bootstrapped Super Admin.
//
// The two ideas that shape everything:
//   - The SEMESTER is the hub: every time-bound record (attendance, marks,
//     assignments, timetable) points at it.
//   - A student's class is a YEARLY sticker (Enrollment), not a fixed field —
//     which is what makes promotion + history work.
//
// Deferred to their own feature slices (additive, they hang off the tables here
// and don't reshape the backbone): admission detail tables, bulk import, audit
// log, reference lookups.
//
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Gender {
  MALE
  FEMALE
  OTHER
}

// Account lifecycle. A resigned faculty (or any deactivated login) is INACTIVE.
enum UserStatus {
  ACTIVE
  INACTIVE
}

// Student lifecycle — keeps history when a student leaves.
enum StudentStatus {
  ACTIVE
  GRADUATED
  DROPPED
  TRANSFERRED
}

// Where a role acts. PROGRAM roles (HOD, Faculty, Student, ERP Coordinator) see
// only their own Program; INSTITUTION roles (Super Admin) span everything.
enum RoleScope {
  PROGRAM
  INSTITUTION
}

// The two sessions of an academic year (Anna University structure). The
// curriculum semester a class studies is DERIVED, not stored:
//   semesterNumber = (year - 1) * 2 + (kind == ODD ? 1 : 2)
enum SemesterKind {
  ODD
  EVEN
}

// Attendance status — encodes meaning, not theme (maps to fixed status colors).
enum AttendanceStatus {
  PRESENT
  ABSENT
  OD
  EXCUSED
}

// A leave/OD request kind. OD (on-duty: sports, seminar, college work) counts as
// present; LEAVE (sick/personal) is excused — neutral to the %.
enum LeaveType {
  OD
  LEAVE
}

// Two-stage approval workflow: student applies -> class teacher -> HOD -> issued.
// A rejection at either stage is terminal. Only the final HOD approval writes
// attendance (OD/EXCUSED across the range).
enum LeaveStatus {
  PENDING_TEACHER
  PENDING_HOD
  APPROVED
  REJECTED
}

// Internal assessment kinds (job 4).
enum AssessmentType {
  IA1
  IA2
  MODEL
  ASSIGNMENT
}

// Timetable is Mon-Fri; a working Saturday borrows a weekday's grid.
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
}

// Marital status on a faculty profile.
enum MaritalStatus {
  SINGLE
  MARRIED
  OTHER
}

// ---------------------------------------------------------------------------
// Structure — set up once by the admin.
// A Program is a Degree x Branch pairing (e.g. B.E x CSE); programId is the
// scoping key everyone belongs to. A Class is one group within a program
// (year + section, e.g. II-A).
// ---------------------------------------------------------------------------

model Degree {
  id            String  @id @default(cuid())
  name          String  @unique // "Bachelor of Engineering"
  code          String  @unique // "B.E"
  // Drives both the Year dropdown (1..durationYears) and the Subject
  // semesterNumber range (1..2*durationYears).
  durationYears Int
  isActive      Boolean @default(true)

  programs Program[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id       String  @id @default(cuid())
  name     String  @unique // "Computer Science and Engineering"
  code     String  @unique // "CSE"
  isActive Boolean @default(true)

  programs Program[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Program {
  id       String  @id @default(cuid())
  degreeId String
  degree   Degree  @relation(fields: [degreeId], references: [id])
  branchId String
  branch   Branch  @relation(fields: [branchId], references: [id])
  isActive Boolean @default(true)

  users    User[]
  classes  Class[]
  subjects Subject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One program per Degree x Branch pairing.
  @@unique([degreeId, branchId])
  @@index([branchId])
}

model Class {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])
  year      Int // 1..Degree.durationYears (I-IV)
  section   String // "A".."H"

  // The class in-charge / mentor (optional). A staff User.
  advisorId String?
  advisor   User?   @relation(fields: [advisorId], references: [id])

  isActive Boolean @default(true)

  enrollments        Enrollment[]
  facultyAssignments FacultyAssignment[]
  timetableSlots     TimetableSlot[]
  masterAttendance   MasterAttendance[]
  periodAttendance   PeriodAttendance[]
  leaveRequests      LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, year, section])
  @@index([programId])
  @@index([advisorId])
}

// ---------------------------------------------------------------------------
// People — jobs 2 & 3.
// One permanent User account per person. A Student and a Faculty are each a User
// + their own detail record. Firebase owns identity (the uid); Neon owns
// authorization + all ERP data.
// ---------------------------------------------------------------------------

model User {
  id          String @id @default(cuid())
  // The Firebase Auth uid — the ONLY link between identity and our data.
  firebaseUid String @unique
  email       String @unique
  displayName String

  // The scoping key. Super Admin has none (spans all programs); HOD / Faculty /
  // Student are scoped by it in API guards.
  programId String?
  program   Program? @relation(fields: [programId], references: [id])

  status             UserStatus @default(ACTIVE)
  // Forces a password reset on first login (admin provisions -> temp password
  // -> mustChangePassword flips false).
  mustChangePassword Boolean    @default(true)

  // Present only when this user IS a student / IS staff. The other stays null.
  student        Student?
  facultyProfile FacultyProfile?

  roles UserRole[]

  // Staff relationships.
  advisingClasses    Class[] // classes this user mentors
  facultyAssignments FacultyAssignment[] // subjects this user teaches
  timetableSlots     TimetableSlot[] // scheduled periods this user takes
  markedMaster       MasterAttendance[]  @relation("MasterMarkedBy")
  markedPeriod       PeriodAttendance[]  @relation("PeriodMarkedBy")
  enteredMarks       InternalMark[]      @relation("MarkEnteredBy")
  leaveTeacherActions LeaveRequest[]     @relation("LeaveTeacherAction") // requests this user approved/rejected as class teacher
  leaveHodActions     LeaveRequest[]     @relation("LeaveHodAction")     // requests this user approved/rejected as HOD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
}

model Student {
  id             String        @id @default(cuid())
  // Register number is the official Anna University id and the STUDENT LOGIN
  // HANDLE (register number + password). Required, unique anchor.
  registerNumber String        @unique
  // College-given roll number. Optional, unique when present. Not for login.
  rollNumber     String?       @unique
  dateOfBirth    DateTime
  phone          String
  gender         Gender?
  status         StudentStatus @default(ACTIVE)

  // Every student is backed by exactly one User (their Firebase-linked account).
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  enrollments      Enrollment[]
  masterAttendance MasterAttendance[]
  periodAttendance PeriodAttendance[]
  internalMarks    InternalMark[]
  leaveRequests    LeaveRequest[]

  // + admission detail (profile, guardians, address, education, banks,
  //   documents) lands in the student-records slice — hangs off studentId.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FacultyProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "designation" is the HR title (e.g. "Asst. Professor"), distinct from the
  // login role on User. staffId is the college-assigned id.
  designation String
  staffId     String @unique

  phone          String
  emergencyPhone String?
  gender         Gender?
  dateOfBirth    DateTime?
  maritalStatus  MaritalStatus?
  fatherName     String?
  motherName     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Access & roles — configurable RBAC.
// Roles and permissions are DATA, not hard-coded: the admin composes custom
// roles in a UI. CASL abilities are built in code from the
// UserRole -> Role -> Permission mapping. Super Admin is bootstrapped once.
// ---------------------------------------------------------------------------

model Role {
  id          String    @id @default(cuid())
  name        String    @unique // "Super Admin", "HOD", "Faculty", "Student", "ERP Coordinator"
  description String?
  // Where the role acts — PROGRAM (own program only) or INSTITUTION (all).
  scope       RoleScope @default(PROGRAM)
  // System roles (seeded) can't be deleted via the UI.
  isSystem    Boolean   @default(false)

  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id      String @id @default(cuid())
  // CASL-shaped: action + subject, e.g. action="manage" subject="all",
  // action="mark" subject="Attendance".
  action  String
  subject String

  roles RolePermission[]

  @@unique([action, subject])
}

// A role ASSIGNMENT to a person. Revoking/reassigning (e.g. HOD rotation) is a
// row delete/create here — the User account never changes.
model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ---------------------------------------------------------------------------
// Time — what makes "semester-wise" work.
// The Semester is the hub for attendance + marks; everything time-bound points
// at it. Exactly one AcademicYear and one Semester are active at a time
// (enforced in app).
// ---------------------------------------------------------------------------

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique // "2025-2026"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  semesters   Semester[]
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Semester {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  kind           SemesterKind // ODD / EVEN
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(false)

  facultyAssignments FacultyAssignment[]
  timetableSlots     TimetableSlot[]
  masterAttendance   MasterAttendance[]
  periodAttendance   PeriodAttendance[]
  internalMarks      InternalMark[]
  leaveRequests      LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One Odd + one Even per year.
  @@unique([academicYearId, kind])
  @@index([academicYearId])
}

// ---------------------------------------------------------------------------
// Placement — Enrollment is the yearly sticker that drives promotion.
// Where a student sits THIS year. Promotion = a new row next year; old rows
// stay as history. The class's year is read through classId -> Class.year.
// ---------------------------------------------------------------------------

model Enrollment {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  classId        String
  class          Class        @relation(fields: [classId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A student sits in exactly one class per academic year.
  @@unique([studentId, academicYearId])
  @@index([classId])
  @@index([academicYearId])
}

// ---------------------------------------------------------------------------
// Curriculum — jobs 1 & 4 hang off these.
// Subject is a reusable per-program catalog. FacultyAssignment says who MAY
// teach/mark. TimetableSlot is the weekly grid that drives the attendance
// screen.
// ---------------------------------------------------------------------------

model Subject {
  id             String  @id @default(cuid())
  programId      String
  program        Program @relation(fields: [programId], references: [id])
  name           String
  code           String
  // 1..(2 * degree years) — the curriculum semester this subject belongs to.
  semesterNumber Int
  isActive       Boolean @default(true)

  facultyAssignments FacultyAssignment[]
  timetableSlots     TimetableSlot[]
  periodAttendance   PeriodAttendance[]
  internalMarks      InternalMark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, code])
  @@index([programId])
}

// Who teaches what, to which class, this semester. The coarse authorization gate
// for entering internal marks. A TimetableSlot is the scheduled instance of one.
model FacultyAssignment {
  id         String   @id @default(cuid())
  facultyId  String
  faculty    User     @relation(fields: [facultyId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  classId    String
  class      Class    @relation(fields: [classId], references: [id])
  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, subjectId, classId, semesterId])
  @@index([subjectId])
  @@index([classId])
  @@index([semesterId])
}

// The weekly schedule — what subject/faculty sits in each (day, period) for a
// class. Mon-Fri only; a working Saturday borrows a weekday's grid. Drives the
// attendance screen and "today's classes".
model TimetableSlot {
  id         String    @id @default(cuid())
  classId    String
  class      Class     @relation(fields: [classId], references: [id])
  semesterId String
  semester   Semester  @relation(fields: [semesterId], references: [id])
  dayOfWeek  DayOfWeek
  period     Int // 1..8
  subjectId  String
  subject    Subject   @relation(fields: [subjectId], references: [id])
  facultyId  String
  faculty    User      @relation(fields: [facultyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One thing per class per slot.
  @@unique([classId, semesterId, dayOfWeek, period])
  @@index([semesterId])
  @@index([subjectId])
  @@index([facultyId])
}

// ---------------------------------------------------------------------------
// Records — the daily output (jobs 1 & 4).
// MasterAttendance is the official DAY attendance (set from period 1);
// PeriodAttendance is the hour-wise, subject-level detail. Both are
// semester-scoped for reports.
// ---------------------------------------------------------------------------

// The official day attendance — one row per student per day, drives overall
// attendance %. Auto-seeded from period 1 (present in the first period -> present
// today), but the class teacher (advisor) can correct it: a corrected row sets
// manuallyAdjusted=true, which the period-1 auto-seed then leaves untouched.
model MasterAttendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id])
  classId    String
  class      Class            @relation(fields: [classId], references: [id])
  semesterId String
  semester   Semester         @relation(fields: [semesterId], references: [id])
  date       DateTime         @db.Date
  status     AttendanceStatus
  // True once the class teacher has manually set this day's record — the period-1
  // auto-seed skips these so a re-mark of period 1 can't clobber a correction.
  manuallyAdjusted Boolean    @default(false)
  markedById String
  markedBy   User             @relation("MasterMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One master row per student per day.
  @@unique([studentId, date])
  @@index([classId])
  @@index([semesterId])
  @@index([date])
}

// Hour-by-hour, subject-wise — one row per student per period. Feeds subject
// attendance %; period 1 also sets that student's MasterAttendance for the day.
model PeriodAttendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id])
  subjectId  String
  subject    Subject          @relation(fields: [subjectId], references: [id])
  classId    String
  class      Class            @relation(fields: [classId], references: [id])
  semesterId String
  semester   Semester         @relation(fields: [semesterId], references: [id])
  date       DateTime         @db.Date
  period     Int // 1..8
  status     AttendanceStatus
  markedById String
  markedBy   User             @relation("PeriodMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A student can only be in one place per period.
  @@unique([studentId, date, period])
  @@index([subjectId])
  @@index([classId])
  @@index([semesterId])
  @@index([date])
}

// Per student, per subject, per semester, per assessment (job 4).
model InternalMark {
  id         String         @id @default(cuid())
  studentId  String
  student    Student        @relation(fields: [studentId], references: [id])
  subjectId  String
  subject    Subject        @relation(fields: [subjectId], references: [id])
  semesterId String
  semester   Semester       @relation(fields: [semesterId], references: [id])
  assessment AssessmentType
  maxMark    Decimal
  obtained   Decimal
  // Who entered the marks (audit).
  markedById String?
  markedBy   User?          @relation("MarkEnteredBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One row per assessment per subject per student per semester.
  @@unique([studentId, subjectId, semesterId, assessment])
  @@index([subjectId])
  @@index([semesterId])
}

// ---------------------------------------------------------------------------
// Leave / OD — a student's request to be excused (LEAVE) or marked on-duty (OD)
// over a date range, approved in two stages (class teacher -> HOD). Only the
// final HOD approval writes attendance (OD -> present, LEAVE -> EXCUSED) across
// the range, atomically. The class is captured at apply time (the student's
// active-year enrollment) so the teacher/HOD scope checks and the attendance
// write both target the right class + semester.
// ---------------------------------------------------------------------------

model LeaveRequest {
  id         String      @id @default(cuid())
  studentId  String
  student    Student     @relation(fields: [studentId], references: [id])
  classId    String
  class      Class       @relation(fields: [classId], references: [id])
  semesterId String
  semester   Semester    @relation(fields: [semesterId], references: [id])
  type       LeaveType
  fromDate   DateTime    @db.Date
  toDate     DateTime    @db.Date
  reason     String
  status     LeaveStatus @default(PENDING_TEACHER)

  // Stage-1 (class teacher) action audit.
  teacherActionById String?
  teacherActionBy   User?     @relation("LeaveTeacherAction", fields: [teacherActionById], references: [id])
  teacherActionAt   DateTime?

  // Stage-2 (HOD) action audit.
  hodActionById String?
  hodActionBy   User?     @relation("LeaveHodAction", fields: [hodActionById], references: [id])
  hodActionAt   DateTime?

  // Set when rejected at either stage (terminal).
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([classId])
  @@index([semesterId])
  @@index([status])
}
