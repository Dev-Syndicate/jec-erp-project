# ---------------------------------------------------------------------------
# Neon Postgres
# ---------------------------------------------------------------------------
# These connection strings are SERVER-SIDE ONLY. They must never reach a client
# (no NEXT_PUBLIC_ prefix, never returned in an API response, never shipped in
# the Flutter app). Copy this file to `.env` and fill in real values.
#
# Get both strings from the Neon console:
#   Project > Connect > choose your branch/database.
#   - "Pooled connection"  -> DATABASE_URL      (has `-pooler` in the host)
#   - "Direct connection"  -> DIRECT_URL        (no `-pooler` in the host)
#
# Why two URLs: the app queries through Neon's connection pooler (PgBouncer),
# but Prisma Migrate needs a direct, unpooled connection to run migrations.

# Pooled URL — used by the app at runtime. Note `-pooler` in the host.
DATABASE_URL="postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require"

# Direct (unpooled) URL — used by `prisma migrate` / `prisma db push` only.
DIRECT_URL="postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require"

# ---------------------------------------------------------------------------
# Firebase — CLIENT config (web)
# ---------------------------------------------------------------------------
# These are PUBLIC by design — they ship to the browser, so they carry the
# NEXT_PUBLIC_ prefix. They identify the project; they are NOT secrets and grant
# no access on their own (security is enforced by our API + Firebase rules).
# Fetch with: firebase apps:sdkconfig WEB <appId> --project <projectId>
NEXT_PUBLIC_FIREBASE_API_KEY="<apiKey>"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="<projectId>.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="<projectId>"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="<projectId>.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="<messagingSenderId>"
NEXT_PUBLIC_FIREBASE_APP_ID="<appId>"

# ---------------------------------------------------------------------------
# Firebase Admin SDK — SERVER-SIDE SECRET (never NEXT_PUBLIC_, never committed)
# ---------------------------------------------------------------------------
# Used by API routes to verify ID tokens. Generate the private key in the
# console: Project settings > Service accounts > Generate new private key.
# Paste the JSON's three fields below. Keep the private key on ONE line with
# literal \n escapes (the app replaces \n with newlines at load time).
FIREBASE_ADMIN_PROJECT_ID="<projectId>"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxxxx@<projectId>.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<...>\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Seed — Super Admin bootstrap (used ONLY by `prisma db seed`, never at runtime)
# ---------------------------------------------------------------------------
# The Super Admin is seeded once via the protected seed script (no higher role
# exists to create it). It still gets mustChangePassword=true and should reset
# on first login.
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_TEMP_PASSWORD="change-me-on-first-login"
SUPER_ADMIN_NAME="Super Admin"
